import seaborn as sns
import matplotlib.pyplot as plt

# Clean column names by stripping whitespace
df.columns = df.columns.str.strip()

plt.figure(figsize=(10, 6))
sns.regplot(x='study_hours', y='exam_score', data=df)
plt.title('Study Hours vs. Exam Score with Trendline')
plt.xlabel('Study Hours')
plt.ylabel('Exam Score')
plt.grid(True)
plt.show()

import seaborn as sns
import matplotlib.pyplot as plt

plt.figure(figsize=(10, 6))
sns.scatterplot(x='sleep_hours', y='exam_score', hue='study_hours_bucket', data=df, palette='viridis')
plt.title('Sleep Hours vs. Exam Score by Study Hours Bucket')
plt.xlabel('Sleep Hours')
plt.ylabel('Exam Score')
plt.grid(True)
plt.legend(title='Study Hours Bucket')
plt.show()
